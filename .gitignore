# ============================================================================
# Go Project .gitignore - Best Practices
# ============================================================================

# ============================================================================
# Go Binaries and Build Artifacts
# ============================================================================

# Compiled binaries (main executable)
sorttf
sorttf-*
/cmd/sorttf/sorttf

# Test binaries
*.test
sorttf-test
integration/sorttf-test

# Go workspace files (multi-module workspaces)
go.work
go.work.sum

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# ============================================================================
# Go Test and Coverage Files
# ============================================================================

# Coverage files
*.out
coverage.txt
coverage.html
*.cover
*.coverprofile
c.out

# Test cache
.test-cache/

# Benchmark results
*.bench
benchmarks/

# ============================================================================
# Go Build Cache and Temporary Files
# ============================================================================

# Temporary files
*.tmp
*.swp
*.swo
*~
.*.swp

# Vendor directory (if using vendoring instead of modules)
vendor/

# ============================================================================
# IDEs and Editors
# ============================================================================

# JetBrains IDEs (IntelliJ, GoLand, etc.)
.idea/
*.iml
*.iws
*.ipr

# Visual Studio Code
.vscode/
*.code-workspace
.history/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ============================================================================
# Operating System Files
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*
.nfs*

# ============================================================================
# Environment and Secrets
# ============================================================================

# Environment files
.env
.env.local
.env.*.local
*.env

# Secrets and credentials
secrets/
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx

# ============================================================================
# Logs and Debugging
# ============================================================================

# Log files
*.log
logs/
*.log.*

# Debug files
debug
debug.test
__debug_bin
.dlv/

# Profiling files
*.prof
*.pprof
cpu.prof
mem.prof
profile.out

# ============================================================================
# Documentation and Build Output
# ============================================================================

# Generated documentation
docs/_build/
site/

# Build output directories
dist/
build/
bin/
release/
out/

# ============================================================================
# Dependencies and Package Managers
# ============================================================================

# Air (live reload)
.air.toml
tmp/

# Mockery
mocks/

# ============================================================================
# Project-Specific
# ============================================================================

# Integration test temporary files
integration/*.tf
integration/*.hcl
integration/test-*

# Backup files
*.bak
*.backup
*.orig

# Archive files
*.tar
*.tar.gz
*.zip
*.7z

# ============================================================================
# CI/CD and Testing
# ============================================================================

# Test results
test-results/
junit.xml
test-report.xml

# Code coverage reports
coverage/
htmlcov/

# Mutation testing
.mutants/

# ============================================================================
# Optional: Uncomment if needed
# ============================================================================

# Go module cache (usually don't ignore, but some prefer to)
# go.sum should be committed for libraries
# go.sum

# Proto generated files (if using gRPC/protobuf)
# *.pb.go
# *.pb.gw.go

# Wire generated files (if using Wire for DI)
# wire_gen.go

# Swagger/OpenAPI generated files
# docs/swagger.json
# docs/swagger.yaml
